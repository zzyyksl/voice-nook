# 复制成 .env，填好后 mcp-server.mjs 启动时会自动读取（同目录）。
# 不要把 .env 提交进git（.gitignore已经排除）、也不要贴进聊天。

# ① 手机TG搜 @userinfobot 发条消息就能拿到你的数字ID
VOICE_NOOK_ALLOWED_USER=

# ② @BotFather 给的 bot token
VOICE_NOOK_TG_TOKEN=

# ③④ MiniMax 账户管理里的 GroupId / 接口密钥里创建的 API Key
VOICE_NOOK_MM_GROUP=
VOICE_NOOK_MM_KEY=
# MiniMax 区分国际/国内域名，key跟域名对不上会401。
# Ada的账户是国内的，跟stackchan那边验证过一致，默认已经是 https://api.minimaxi.com，一般不用改。
# VOICE_NOOK_MM_BASE_URL=https://api.minimaxi.com

# ⑤ 系统音色或克隆音色的 ID（stackchan那边克隆的Wren音色ID应该能直接复用）
VOICE_NOOK_VOICE_ID=

# ⑥⑦ 火山引擎控制台"流式语音识别大模型"应用里的 APP ID / Access Token
VOICE_NOOK_VOLC_APP_ID=
VOICE_NOOK_VOLC_ACCESS_KEY=

# 可选：本地HTTP/WebSocket端口，默认18010
# VOICE_NOOK_PORT=18010

# 可选：监听地址，默认127.0.0.1（只监听本机，配合cloudflared隧道对外，更安全）。
# 如果你不走隧道、需要服务直接对外监听，可显式设为 0.0.0.0——但那样你要自己确保
# 防火墙/安全组已经限制了18010的来源，不要裸奔在公网上。
# VOICE_NOOK_HOST=127.0.0.1
